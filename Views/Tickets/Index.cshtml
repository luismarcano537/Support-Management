@model IEnumerable<SupportManagement.Models.Ticket>

@{
    ViewData["Title"] = "Fila de Atendimentos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
        <a asp-action="Create" class="btn btn-primary">Novo Ticket</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-striped table-hover mt-3">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Título</th>
                        <th>Solicitante</th>
                        <th>Categoria</th>
                        <th>Status</th>
                        <th>Abertura</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Name</td>
                            <td>@item.Requester</td>
                            <td>@item.Category.Name</td> 
                            <td>
                                @if (item.Situation == SupportManagement.Models.Enums.Status.Active)
                                {
                                    <span class="badge bg-warning text-dark">Aberto</span>
                                }
                                else if (item.Situation == SupportManagement.Models.Enums.Status.InProgress)
                                {
                                    <span class="badge bg-info text-dark">Em Andamento</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Resolvido</span>
                                }
                            </td>
                            <td>@item.CreationDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Atualizar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!Model.Any())
            {
                <div class="alert alert-info text-center" role="alert">
                    Nenhum ticket encontrado na base de dados.
                </div>
            }
        </div>
    </div>
</div>